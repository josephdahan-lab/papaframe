#!/bin/bash
# PapaFrame CLI — quick commands from the terminal.
#
# Installed to /usr/local/bin/papaframe by the installer so you can run:
#   papaframe version
#   papaframe status
#   papaframe start / stop / restart
#   papaframe screen on / off
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# When installed to /usr/local/bin, REPO_ROOT is baked in by the installer's
# sed command.  When run from the repo directly, derive it from the script
# location.  The fallback glob covers the common ~/papaframe layout.
if [ -n "${PAPAFRAME_ROOT:-}" ]; then
    REPO_ROOT="$PAPAFRAME_ROOT"
elif [ -f "$SCRIPT_DIR/../version.py" ]; then
    REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "$HOME/papaframe/version.py" ]; then
    REPO_ROOT="$HOME/papaframe"
else
    REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

VERSION_FILE="$REPO_ROOT/version.py"

get_version() {
    if [ -f "$VERSION_FILE" ]; then
        grep -oP "(?<=__version__ = ')([^']+)" "$VERSION_FILE" 2>/dev/null \
            || echo "unknown"
    else
        echo "unknown"
    fi
}

get_server_variant() {
    if systemctl is-active --quiet papaframe-server 2>/dev/null; then
        local cmd
        cmd="$(systemctl show papaframe-server -p ExecStart --value 2>/dev/null)"
        if echo "$cmd" | grep -q "server_lite"; then
            echo "lite"
        else
            echo "full"
        fi
    elif [ -f "$REPO_ROOT/server_lite.py" ] && [ ! -f "$REPO_ROOT/.venv/bin/python3" ]; then
        echo "lite"
    else
        echo "full"
    fi
}

get_port() {
    local cfg="$REPO_ROOT/config.sh"
    if [ -f "$cfg" ]; then
        grep -oP '(?<=SERVER_PORT=)\d+' "$cfg" 2>/dev/null || echo "8000"
    else
        echo "8000"
    fi
}

api_call() {
    local method="$1" path="$2" data="$3"
    local port
    port="$(get_port)"
    local url="http://127.0.0.1:${port}${path}"
    if [ "$method" = "GET" ]; then
        curl -sf --max-time 5 "$url" 2>/dev/null
    else
        curl -sf --max-time 5 -X POST \
             -H "Content-Type: application/json" \
             -d "${data:-{}}" "$url" 2>/dev/null
    fi
}

cmd_version() {
    local ver variant board arch ram
    ver="$(get_version)"
    variant="$(get_server_variant)"
    echo "PapaFrame $ver ($variant)"

    # Extra details with -v
    if [ "${1:-}" = "-v" ] || [ "${1:-}" = "--verbose" ]; then
        board="unknown"
        for f in /sys/firmware/devicetree/base/model /proc/device-tree/model; do
            if [ -r "$f" ]; then
                board="$(tr -d '\0' < "$f")"
                break
            fi
        done
        arch="$(uname -m)"
        ram=$(( $(awk '/^MemTotal:/ {print $2}' /proc/meminfo) / 1024 ))
        echo "  board:   $board"
        echo "  arch:    $arch, ${ram} MB RAM"
        echo "  repo:    $REPO_ROOT"
        echo "  python:  $(python3 --version 2>&1)"

        if systemctl is-active --quiet papaframe-server 2>/dev/null; then
            echo "  service: active"
        else
            echo "  service: inactive"
        fi
    fi
}

cmd_status() {
    local resp
    resp="$(api_call GET /api/status)" || {
        echo "Server not reachable. Is papaframe-server running?"
        exit 1
    }
    local running pid duration
    running="$(echo "$resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print('Running' if d['running'] else 'Stopped')")"
    pid="$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin).get('pid') or '-')")"
    duration="$(echo "$resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print(f\"{d['duration']}s\" if d.get('duration') else '-')")"
    echo "Slideshow: $running"
    echo "PID:       $pid"
    echo "Duration:  $duration"
}

cmd_start() {
    api_call POST /api/start '{}' > /dev/null && echo "Slideshow started." \
        || echo "Failed to start slideshow."
}

cmd_stop() {
    api_call POST /api/stop '{}' > /dev/null && echo "Slideshow stopped." \
        || echo "Failed to stop slideshow."
}

cmd_restart() {
    api_call POST /api/restart '{}' > /dev/null && echo "Slideshow restarted." \
        || echo "Failed to restart slideshow."
}

cmd_screen() {
    local want="${1:-}"
    if [ "$want" != "on" ] && [ "$want" != "off" ]; then
        echo "Usage: papaframe screen on|off" >&2
        exit 2
    fi
    api_call POST /api/screen "{\"state\":\"$want\"}" > /dev/null \
        && echo "Screen $want." \
        || echo "Failed to set screen $want."
}

usage() {
    cat <<HELP
Usage: papaframe <command> [args]

Commands:
  version [-v]       Show PapaFrame version (add -v for board details)
  status             Show slideshow status
  start              Start the slideshow
  stop               Stop the slideshow
  restart            Restart the slideshow
  screen on|off      Turn HDMI display on or off

Examples:
  papaframe version
  papaframe status
  papaframe screen off
HELP
}

case "${1:-}" in
    version|--version|-v|-V)  shift; cmd_version "$@" ;;
    status)                   cmd_status ;;
    start)                    cmd_start ;;
    stop)                     cmd_stop ;;
    restart)                  cmd_restart ;;
    screen)                   shift; cmd_screen "$@" ;;
    help|--help|-h)           usage ;;
    "")                       usage; exit 2 ;;
    *)                        echo "Unknown command: $1" >&2; usage; exit 2 ;;
esac
